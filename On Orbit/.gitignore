# Autogenerated solution/project files
# =========================
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# =========================
# Unity Rider / VS / VSCode
# =========================
.vs/
.idea/
.vscode/

# Rider
*.sln.iml

# =========================
# OS generated files
# =========================
.DS_Store
Thumbs.db
desktop.ini

